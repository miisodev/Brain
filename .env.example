# Trilium Brain MCP — environment variables
# Copy this file to .env and fill in your values.

# URL of your TriliumNext instance
# Local desktop (default):
TRILIUM_BASE_URL=http://localhost:8080
# Remote / cloud (VPS or reverse proxy):
# TRILIUM_BASE_URL=https://trilium.yourdomain.com

# ETAPI token — create in Trilium: Options → ETAPI → Create token
TRILIUM_ETAPI_TOKEN=

# (Optional) Disable TLS verification for self-signed certificates.
# Only use on private/trusted networks — never in public-facing deployments.
# NODE_TLS_REJECT_UNAUTHORIZED=0
